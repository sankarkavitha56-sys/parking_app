# Backend environment variables. Copy to .env and fill in real values.
# Never commit the real .env file.

# Port the API server listens on.
PORT=3000

# MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017/parking

# Secret used to sign JWT auth tokens. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret

# Razorpay credentials (only needed if/when payment integration is enabled).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
